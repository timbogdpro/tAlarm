<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/alarm_gradient"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:padding="24dp">

    <Space
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        android:layout_weight="0.6" />

    <ImageView
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:layout_marginBottom="16dp"
        android:alpha="0.95"
        android:contentDescription="@string/alarm_ringing"
        android:src="@drawable/ic_alarm"
        app:tint="@color/white" />

    <TextView
        android:id="@+id/clock"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFeatureSettings="tnum"
        android:letterSpacing="-0.02"
        android:text="00:00"
        android:textColor="@color/white"
        android:textSize="80sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/alarm_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:alpha="0.95"
        android:gravity="center"
        android:textColor="@color/white"
        android:textSize="22sp" />

    <LinearLayout
        android:id="@+id/math_panel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="36dp"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/math_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:alpha="0.95"
            android:gravity="center"
            android:text="@string/solve_to_dismiss"
            android:textColor="@color/white"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/math_problem"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/white"
            android:textSize="44sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/math_answer"
            android:layout_width="220dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:autofillHints=""
            android:backgroundTint="@color/white"
            android:gravity="center"
            android:hint="@string/your_answer"
            android:inputType="number"
            android:textColor="@color/white"
            android:textColorHint="#88FFFFFF"
            android:textSize="28sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/shake_panel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="36dp"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/shake_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/shake_to_dismiss"
            android:textColor="@color/white"
            android:textSize="20sp" />

        <ProgressBar
            android:id="@+id/shake_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:progressTint="@color/white"
            android:progressBackgroundTint="#55FFFFFF" />
    </LinearLayout>

    <Space
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/dismiss_btn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="64dp"
        android:text="@string/turn_off"
        android:textColor="@color/alarm_grad_bottom"
        android:textSize="18sp"
        android:textStyle="bold"
        app:backgroundTint="@color/white"
        app:cornerRadius="20dp"
        app:icon="@drawable/ic_alarm_off"
        app:iconGravity="textStart"
        app:iconTint="@color/alarm_grad_bottom" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/snooze_btn"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:minHeight="52dp"
        android:text="@string/snooze"
        android:textColor="@color/white"
        android:textSize="16sp"
        app:icon="@drawable/ic_snooze"
        app:iconGravity="textStart"
        app:iconTint="@color/white"
        app:rippleColor="#33FFFFFF" />
</LinearLayout>
