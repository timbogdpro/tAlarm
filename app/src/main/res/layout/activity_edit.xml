<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Time hero (tap to change) -->
        <LinearLayout
            android:id="@+id/time_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingVertical="12dp">

            <TextView
                android:id="@+id/time_display"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/app_heading"
                android:fontFeatureSettings="tnum"
                android:letterSpacing="-0.02"
                android:text="07:00"
                android:textColor="?attr/colorOnSurface"
                android:textSize="76sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/app_body"
                android:text="@string/change_time"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Label -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="@string/label_hint"
            app:startIconDrawable="@drawable/ic_alarm">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/label_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:maxLines="1" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Repeat / days -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="?attr/colorSurfaceContainer"
            app:cardCornerRadius="@dimen/card_radius"
            app:cardElevation="0dp"
            app:strokeColor="?attr/colorOutline"
            app:strokeWidth="@dimen/card_stroke">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_repeat"
                        app:tint="?attr/colorOnSurfaceVariant" />

                    <TextView
                        style="@style/Widget.LoudAlarm.SectionHeader"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="@string/repeat" />
                </LinearLayout>

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:clipToPadding="false"
                    android:scrollbars="none">

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/preset_group"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:singleLine="true"
                        app:singleSelection="true">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_all"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/preset_all" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_weekdays"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/preset_weekdays" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_weekends"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/preset_weekends" />
                    </com.google.android.material.chip.ChipGroup>
                </HorizontalScrollView>

                <com.google.android.material.button.MaterialButtonToggleGroup
                    android:id="@+id/days_group"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:selectionRequired="false"
                    app:singleSelection="false">

                    <com.google.android.material.button.MaterialButton android:id="@+id/day_mon" style="?attr/materialButtonOutlinedStyle" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:minHeight="48dp" android:insetTop="0dp" android:insetBottom="0dp" android:insetLeft="0dp" android:insetRight="0dp" android:paddingHorizontal="0dp" android:text="@string/day_mon" android:textSize="13sp" />
                    <com.google.android.material.button.MaterialButton android:id="@+id/day_tue" style="?attr/materialButtonOutlinedStyle" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:minHeight="48dp" android:insetTop="0dp" android:insetBottom="0dp" android:insetLeft="0dp" android:insetRight="0dp" android:paddingHorizontal="0dp" android:text="@string/day_tue" android:textSize="13sp" />
                    <com.google.android.material.button.MaterialButton android:id="@+id/day_wed" style="?attr/materialButtonOutlinedStyle" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:minHeight="48dp" android:insetTop="0dp" android:insetBottom="0dp" android:insetLeft="0dp" android:insetRight="0dp" android:paddingHorizontal="0dp" android:text="@string/day_wed" android:textSize="13sp" />
                    <com.google.android.material.button.MaterialButton android:id="@+id/day_thu" style="?attr/materialButtonOutlinedStyle" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:minHeight="48dp" android:insetTop="0dp" android:insetBottom="0dp" android:insetLeft="0dp" android:insetRight="0dp" android:paddingHorizontal="0dp" android:text="@string/day_thu" android:textSize="13sp" />
                    <com.google.android.material.button.MaterialButton android:id="@+id/day_fri" style="?attr/materialButtonOutlinedStyle" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:minHeight="48dp" android:insetTop="0dp" android:insetBottom="0dp" android:insetLeft="0dp" android:insetRight="0dp" android:paddingHorizontal="0dp" android:text="@string/day_fri" android:textSize="13sp" />
                    <com.google.android.material.button.MaterialButton android:id="@+id/day_sat" style="?attr/materialButtonOutlinedStyle" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:minHeight="48dp" android:insetTop="0dp" android:insetBottom="0dp" android:insetLeft="0dp" android:insetRight="0dp" android:paddingHorizontal="0dp" android:text="@string/day_sat" android:textSize="13sp" />
                    <com.google.android.material.button.MaterialButton android:id="@+id/day_sun" style="?attr/materialButtonOutlinedStyle" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:minHeight="48dp" android:insetTop="0dp" android:insetBottom="0dp" android:insetLeft="0dp" android:insetRight="0dp" android:paddingHorizontal="0dp" android:text="@string/day_sun" android:textSize="13sp" />
                </com.google.android.material.button.MaterialButtonToggleGroup>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Sound -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="?attr/colorSurfaceContainer"
            app:cardCornerRadius="@dimen/card_radius"
            app:cardElevation="0dp"
            app:strokeColor="?attr/colorOutline"
            app:strokeWidth="@dimen/card_stroke">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_music_note"
                        app:tint="?attr/colorOnSurfaceVariant" />

                    <TextView
                        style="@style/Widget.LoudAlarm.SectionHeader"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="@string/sound" />
                </LinearLayout>

                <RadioGroup
                    android:id="@+id/sound_group"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/preview_btn"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/preview"
                    app:icon="@drawable/ic_play" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Dismiss mode -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="?attr/colorSurfaceContainer"
            app:cardCornerRadius="@dimen/card_radius"
            app:cardElevation="0dp"
            app:strokeColor="?attr/colorOutline"
            app:strokeWidth="@dimen/card_stroke">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_shield"
                        app:tint="?attr/colorOnSurfaceVariant" />

                    <TextView
                        style="@style/Widget.LoudAlarm.SectionHeader"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="@string/dismiss_mode" />
                </LinearLayout>

                <RadioGroup
                    android:id="@+id/dismiss_group"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp">

                    <RadioButton android:id="@+id/dm_button" android:layout_width="match_parent" android:layout_height="wrap_content" android:minHeight="48dp" android:paddingVertical="8dp" android:textSize="16sp" android:text="@string/dm_button" />
                    <RadioButton android:id="@+id/dm_math" android:layout_width="match_parent" android:layout_height="wrap_content" android:minHeight="48dp" android:paddingVertical="8dp" android:textSize="16sp" android:text="@string/dm_math" />
                    <RadioButton android:id="@+id/dm_shake" android:layout_width="match_parent" android:layout_height="wrap_content" android:minHeight="48dp" android:paddingVertical="8dp" android:textSize="16sp" android:text="@string/dm_shake" />
                </RadioGroup>

                <!-- Problem type (shown when "solve a problem" is selected) -->
                <LinearLayout
                    android:id="@+id/math_options"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        style="@style/Widget.LoudAlarm.SectionHeader"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:text="@string/math_type" />

                    <com.google.android.material.button.MaterialButtonToggleGroup
                        android:id="@+id/math_type_group"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:selectionRequired="true"
                        app:singleSelection="true">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/math_addsub"
                            style="?attr/materialButtonOutlinedStyle"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:minWidth="0dp"
                            android:minHeight="48dp"
                            android:insetLeft="0dp"
                            android:insetRight="0dp"
                            android:paddingHorizontal="4dp"
                            android:maxLines="1"
                            android:text="@string/math_addsub"
                            android:textSize="12sp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/math_mult"
                            style="?attr/materialButtonOutlinedStyle"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:minWidth="0dp"
                            android:minHeight="48dp"
                            android:insetLeft="0dp"
                            android:insetRight="0dp"
                            android:paddingHorizontal="4dp"
                            android:maxLines="1"
                            android:text="@string/math_mult"
                            android:textSize="12sp" />
                    </com.google.android.material.button.MaterialButtonToggleGroup>
                </LinearLayout>

                <!-- Shake intensity = number of shakes (shown when "shake the phone" is selected) -->
                <LinearLayout
                    android:id="@+id/shake_options"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            style="@style/Widget.LoudAlarm.SectionHeader"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="@string/shake_count_label" />

                        <TextView
                            android:id="@+id/shake_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textStyle="bold"
                            android:text="15" />
                    </LinearLayout>

                    <com.google.android.material.slider.Slider
                        android:id="@+id/shake_slider"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:valueFrom="5"
                        android:valueTo="40"
                        android:stepSize="1"
                        android:value="15" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Volume & signal -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="?attr/colorSurfaceContainer"
            app:cardCornerRadius="@dimen/card_radius"
            app:cardElevation="0dp"
            app:strokeColor="?attr/colorOutline"
            app:strokeWidth="@dimen/card_stroke">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Volume -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:orientation="horizontal">
                    <ImageView android:layout_width="20dp" android:layout_height="20dp" android:contentDescription="@null" android:src="@drawable/ic_volume_up" app:tint="?attr/colorOnSurfaceVariant" />
                    <TextView style="@style/Widget.LoudAlarm.SectionHeader" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:text="@string/volume" />
                    <TextView android:id="@+id/volume_value" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="?attr/colorOnSurfaceVariant" android:textStyle="bold" android:text="100%" />
                </LinearLayout>
                <com.google.android.material.slider.Slider
                    android:id="@+id/volume_slider"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:valueFrom="0"
                    android:valueTo="100"
                    android:stepSize="1"
                    android:value="100" />

                <!-- Boost -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:orientation="horizontal" android:layout_marginTop="8dp">
                    <ImageView android:layout_width="20dp" android:layout_height="20dp" android:contentDescription="@null" android:src="@drawable/ic_campaign" app:tint="?attr/colorOnSurfaceVariant" />
                    <TextView style="@style/Widget.LoudAlarm.SectionHeader" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:text="@string/boost" />
                    <TextView android:id="@+id/boost_value" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="?attr/colorOnSurfaceVariant" android:textStyle="bold" android:text="+12" />
                </LinearLayout>
                <com.google.android.material.slider.Slider
                    android:id="@+id/boost_slider"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:valueFrom="0"
                    android:valueTo="60"
                    android:stepSize="1"
                    android:value="12" />
                <!-- Snooze -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:orientation="horizontal" android:layout_marginTop="8dp">
                    <ImageView android:layout_width="20dp" android:layout_height="20dp" android:contentDescription="@null" android:src="@drawable/ic_timer" app:tint="?attr/colorOnSurfaceVariant" />
                    <TextView style="@style/Widget.LoudAlarm.SectionHeader" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:text="@string/snooze_minutes" />
                    <TextView android:id="@+id/snooze_value" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="?attr/colorOnSurfaceVariant" android:textStyle="bold" android:text="5" />
                </LinearLayout>
                <com.google.android.material.slider.Slider
                    android:id="@+id/snooze_slider"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:valueFrom="1"
                    android:valueTo="30"
                    android:stepSize="1"
                    android:value="5" />

                <!-- Vibrate -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:orientation="horizontal" android:layout_marginTop="8dp" android:minHeight="48dp">
                    <ImageView android:layout_width="20dp" android:layout_height="20dp" android:contentDescription="@null" android:src="@drawable/ic_vibration" app:tint="?attr/colorOnSurfaceVariant" />
                    <TextView style="@style/Widget.LoudAlarm.SectionHeader" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:text="@string/vibrate" />
                    <com.google.android.material.materialswitch.MaterialSwitch android:id="@+id/vibrate_switch" android:layout_width="wrap_content" android:layout_height="wrap_content" android:checked="true" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/save_btn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp"
            android:minHeight="56dp"
            android:text="@string/save"
            android:textSize="16sp"
            app:icon="@drawable/ic_check"
            app:iconGravity="textStart" />
    </LinearLayout>
</ScrollView>
