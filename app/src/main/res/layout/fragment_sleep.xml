<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Direction toggle -->
        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/mode_group"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:selectionRequired="true"
            app:singleSelection="true">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_wake"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:minWidth="0dp"
                android:minHeight="48dp"
                android:insetLeft="0dp"
                android:insetRight="0dp"
                android:paddingHorizontal="4dp"
                android:maxLines="1"
                android:text="@string/sleep_mode_wake"
                android:textSize="12sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_bed"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:minWidth="0dp"
                android:minHeight="48dp"
                android:insetLeft="0dp"
                android:insetRight="0dp"
                android:paddingHorizontal="4dp"
                android:maxLines="1"
                android:text="@string/sleep_mode_bed"
                android:textSize="12sp" />
        </com.google.android.material.button.MaterialButtonToggleGroup>

        <!-- Input time -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="?attr/colorSurfaceContainer"
            app:cardCornerRadius="@dimen/card_radius"
            app:cardElevation="0dp"
            app:strokeColor="?attr/colorOutline"
            app:strokeWidth="@dimen/card_stroke">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/input_label"
                    style="@style/Widget.LoudAlarm.SectionHeader"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/sleep_input_bed" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/input_time"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        android:fontFamily="@font/app_heading"
                        android:fontFeatureSettings="tnum"
                        android:letterSpacing="-0.02"
                        android:paddingVertical="4dp"
                        android:text="23:00"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="52sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/now_btn"
                        style="?attr/materialButtonOutlinedStyle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/sleep_now" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Hint -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:layout_marginHorizontal="4dp"
            android:fontFamily="@font/app_body"
            android:lineSpacingMultiplier="1.25"
            android:text="@string/sleep_hint"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/results_title"
            style="@style/Widget.LoudAlarm.SectionHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:layout_marginStart="4dp"
            android:layout_marginBottom="4dp"
            android:text="@string/sleep_results_wake" />

        <LinearLayout
            android:id="@+id/results"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp" />
    </LinearLayout>
</ScrollView>
